FROM python:3.12-slim

WORKDIR /app

COPY ./pyproject.toml ./
COPY ./requirements.txt ./
COPY ./src/ /app/
COPY ./streamable_server.py /streamable_server.py

RUN pip install --upgrade pip && pip install -r requirements.txt && pip install "mcp[cli]" uvicorn starlette

CMD ["python", "/streamable_server.py"]
